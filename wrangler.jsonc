{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "localfoundary",
  "compatibility_date": "2026-07-16",
  "main": "worker/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": true
  }
}
